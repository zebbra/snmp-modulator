# NetBox
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your-token-here
NETBOX_TLS_VERIFY=true

# snmp-exporter
SNMP_EXPORTER_URL=http://snmp-exporter:9116
SNMP_EXPORTER_TLS_VERIFY=true
SNMP_EXPORTER_TIMEOUT=30

# Mapping file (path inside container)
MAPPING_FILE=/app/mapping.yaml

# Server
MODULATOR_PORT=8080
MODULATOR_WORKERS=4
MODULATOR_AUTH_TOKEN=
MODULATOR_METRICS_PATH=/metrics
MODULATOR_HOSTNAME=snmp-modulator.example.com

# Set to true to log changes without writing to NetBox
MODULATOR_DRY_RUN=false

# modules.policy, auth.policy, and field names are configured
# in mapping.yaml and can be overridden per-run with CLI args if needed.

# Maximum concurrent probe jobs (across all uvicorn workers)
MODULATOR_MAX_CONCURRENT_RUNS=1

# Enable multiprocess Prometheus metrics when MODULATOR_WORKERS > 1
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
