{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping snmp-modulator",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "title": "snmp-modulator",
  "uid": "snmp-modulator",
  "tags": ["snmp", "netbox", "modulator"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Operational health",
      "id": 100,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Probe jobs (running / queued)",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "targets": [
        {"refId": "A", "expr": "sum(modulator_probe_in_progress)", "legendFormat": "running"},
        {"refId": "B",
         "expr": "clamp_min(sum(modulator_probe_jobs_in_flight) - sum(modulator_probe_in_progress), 0)",
         "legendFormat": "queued"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 5}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value_and_name"}
    },
    {
      "type": "stat",
      "title": "Devices processed (24h)",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "targets": [
        {"refId": "A", "expr": "sum by (result) (increase(modulator_devices_processed_total[24h]))", "legendFormat": "{{result}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0},
        "overrides": [
          {"matcher": {"id": "byName", "options": "success"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "error"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "value_and_name"}
    },
    {
      "type": "stat",
      "title": "Module probe success rate (5m)",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "targets": [
        {"refId": "A",
         "expr": "sum(rate(modulator_module_tests_total{result=\"useful\"}[5m])) / clamp_min(sum(rate(modulator_module_tests_total[5m])), 0.001)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "green", "value": 0.8}
          ]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto"}
    },
    {
      "type": "stat",
      "title": "Auth resolved rate (5m)",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "targets": [
        {"refId": "A",
         "expr": "sum(rate(modulator_auth_probe_results_total{result=\"resolved\"}[5m])) / clamp_min(sum(rate(modulator_auth_probe_results_total[5m])), 0.001)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "green", "value": 0.8}
          ]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto"}
    },

    {
      "type": "row",
      "title": "Activity",
      "id": 101,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Devices processed (per second)",
      "id": 10,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "targets": [
        {"refId": "A", "expr": "sum by (result) (rate(modulator_devices_processed_total[5m]))", "legendFormat": "{{result}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "lineWidth": 1, "fillOpacity": 70}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "success"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "error"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "title": "Module probes (per second)",
      "id": 11,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
      "targets": [
        {"refId": "A", "expr": "sum by (result) (rate(modulator_module_tests_total[5m]))", "legendFormat": "{{result}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "lineWidth": 1, "fillOpacity": 70}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "useful"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "empty"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "error"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "title": "Auth probes (per second)",
      "id": 12,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
      "targets": [
        {"refId": "A", "expr": "sum by (result) (rate(modulator_auth_probe_results_total[5m]))", "legendFormat": "{{result}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "lineWidth": 1, "fillOpacity": 70}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "resolved"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "skipped"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "failed"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "title": "Performance",
      "id": 102,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Probe job duration (p50/p95/p99)",
      "id": 20,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(modulator_probe_duration_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(modulator_probe_duration_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(modulator_probe_duration_seconds_bucket[5m])))", "legendFormat": "p99"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "title": "Module test duration p95 (top 10)",
      "id": 21,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "targets": [
        {"refId": "A",
         "expr": "topk(10, histogram_quantile(0.95, sum by (module, le) (rate(modulator_module_test_duration_seconds_bucket[5m]))))",
         "legendFormat": "{{module}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "spanNulls": true}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "title": "NetBox writes & refresh",
      "id": 103,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "NetBox updates (per second)",
      "id": 30,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {"refId": "A", "expr": "sum by (action) (rate(modulator_netbox_updates_total[5m]))", "legendFormat": "{{action}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "lineWidth": 1, "fillOpacity": 70}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "changed"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "unchanged"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "gray"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "title": "NetBox device-count refresh duration",
      "id": 31,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"refId": "A",
         "expr": "histogram_quantile(0.95, sum by (le) (rate(modulator_netbox_devices_refresh_duration_seconds_bucket[1h])))",
         "legendFormat": "p95"},
        {"refId": "B",
         "expr": "rate(modulator_netbox_devices_refresh_duration_seconds_sum[1h]) / clamp_min(rate(modulator_netbox_devices_refresh_duration_seconds_count[1h]), 0.001)",
         "legendFormat": "avg"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "title": "NetBox inventory — auth profiles",
      "id": 104,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Devices by auth profile",
      "id": 40,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 12, "w": 12, "x": 0, "y": 33},
      "targets": [
        {"refId": "A", "expr": "sort_desc(modulator_netbox_devices_by_auth)", "legendFormat": "{{profile}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "blue", "value": 1}
          ]}
        }
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color"}
    },
    {
      "type": "table",
      "title": "Unused auth profiles",
      "id": 41,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 12, "w": 12, "x": 12, "y": 33},
      "targets": [
        {"refId": "A", "expr": "modulator_netbox_devices_by_auth == 0", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "Value": true, "instance": true, "job": true},
          "renameByName": {"profile": "Auth profile (zero devices)"}
        }},
        {"id": "sortBy", "options": {"sort": [{"field": "Auth profile (zero devices)"}]}}
      ],
      "fieldConfig": {"defaults": {}}
    },

    {
      "type": "row",
      "title": "NetBox inventory — modules",
      "id": 105,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Devices by module (top 30)",
      "id": 50,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 14, "w": 12, "x": 0, "y": 46},
      "targets": [
        {"refId": "A", "expr": "topk(30, modulator_netbox_devices_by_module)", "legendFormat": "{{module}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "blue", "value": 1}
          ]}
        }
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color"}
    },
    {
      "type": "table",
      "title": "Unused modules",
      "id": 51,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 14, "w": 12, "x": 12, "y": 46},
      "targets": [
        {"refId": "A", "expr": "modulator_netbox_devices_by_module == 0", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "Value": true, "instance": true, "job": true},
          "renameByName": {"module": "Module (zero devices)"}
        }},
        {"id": "sortBy", "options": {"sort": [{"field": "Module (zero devices)"}]}}
      ],
      "fieldConfig": {"defaults": {}}
    },

    {
      "type": "row",
      "title": "Module churn",
      "id": 106,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 60},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Module add/remove rate",
      "id": 60,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 61},
      "targets": [
        {"refId": "A", "expr": "sum by (action) (rate(modulator_module_changes_total[5m]))", "legendFormat": "{{action}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "lineWidth": 1, "fillOpacity": 70}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "added"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "removed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "table",
      "title": "Top module changes (24h)",
      "id": 61,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 61},
      "targets": [
        {"refId": "A",
         "expr": "topk(20, sum by (module, action) (increase(modulator_module_changes_total[24h])))",
         "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true},
          "renameByName": {"module": "Module", "action": "Action", "Value": "Count (24h)"}
        }},
        {"id": "sortBy", "options": {"sort": [{"field": "Count (24h)", "desc": true}]}}
      ],
      "fieldConfig": {"defaults": {"decimals": 0}}
    }
  ]
}
